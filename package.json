{
  "name": "clawcast",
  "version": "1.0.0",
  "description": "Watch AI coding agents work in real-time",
  "main": "index.js",
  "type": "module",
  "bin": {
    "clawcast": "./dist/cli.js",
    "clawcast-dev": "./dist/cli-dev.js"
  },
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
